@page "/"
@rendermode InteractiveServer
@using Turmerik.Utility.BlazorServerApp.Components.Pages.TextUtils
@using Turmerik.Utility.BlazorServerApp.Components.Pages.TextTransform
@using Turmerik.Utility.BlazorServerApp.Components.Pages.OpenMultipleLinks
@using Turmerik.Utility.BlazorServerApp.Components.Pages.FetchMultipleLinks
@using Turmerik.Utility.BlazorServerApp.Components.Pages.GenerateClnblTypes

<PageTitle>Turmerik Utility</PageTitle>

<div class="tab-nav">
    @for (int i = 0; i < _tabs.Length; i++)
    {
        var idx = i;
        <button class="tab-btn @(_activeTab == idx ? "active" : "")"
                @onclick="() => _activeTab = idx">
            @_tabs[idx]
        </button>
    }
</div>

<div class="tab-content">
    @if (_activeTab == 0)
    {
        <TextUtilsTab />
    }
    else if (_activeTab == 1)
    {
        <TextTransformTab />
    }
    else if (_activeTab == 2)
    {
        <OpenMultipleLinksTab />
    }
    else if (_activeTab == 3)
    {
        <FetchMultipleLinksTab />
    }
    else if (_activeTab == 4)
    {
        <GenerateClnblTypesTab />
    }
</div>

@code {
    private int _activeTab;

    private readonly string[] _tabs =
    [
        "Text Utils",
        "Text Transform",
        "Open Multiple Links",
        "Fetch Multiple Links",
        "Generate Clnbl Types"
    ];
}
