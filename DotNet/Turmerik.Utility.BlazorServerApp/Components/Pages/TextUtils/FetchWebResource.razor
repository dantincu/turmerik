@inject IAppSettings AppSettings
@inject AppNotificationService Notify
@inject ClipboardService Clipboard
@inject IHtmlDocTitleRetriever HtmlTitleRetriever

<div class="panel">
    <div class="panel-title">Fetch Web Resource</div>

    <div class="form-group">
        <label>Resource URL</label>
        <div class="form-row">
            <input type="url" @bind="_url" @bind:event="oninput" @onkeyup="OnUrlKeyUp"
                   placeholder="Paste URL here… then press Enter to fetch" title="Enter=fetch | Shift+Enter=refresh MD link | Ctrl+Enter=enable MD-link auto-copy+fetch | Ctrl+Shift+Enter=disable+fetch" />
            <button class="btn btn-primary" @onclick="FetchAsync" disabled="@_loading">
                @(_loading ? "Fetching…" : "⬇ Fetch")
            </button>
        </div>
    </div>

    <div class="form-group">
        <label>Title</label>
        <div class="form-row">
            <input type="text" @bind="_title" @bind:event="oninput" @onkeyup="OnTitleKeyUp"
                   placeholder="Title will appear here…" title="Enter=refresh MD link+copy | Ctrl+Enter=enable title auto-copy | Ctrl+Shift+Enter=disable" />
            <button class="btn btn-icon" @onclick="CopyTitle" title="Copy title">⧉</button>
        </div>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_autoTitleToCB" />
            Auto-copy title after fetch
        </label>
    </div>

    <div class="form-group">
        <label>Markdown Link</label>
        <div class="form-row">
            <input type="text" @bind="_mdLink" @bind:event="oninput" @onkeyup="OnMdLinkKeyUp"
                   placeholder="[Title](URL)" title="Enter=refresh MD link+copy | Ctrl+Enter=enable MD-link auto-copy | Ctrl+Shift+Enter=disable" />
            <button class="btn btn-icon" @onclick="CopyMdLink" title="Copy markdown link">⧉</button>
        </div>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_autoMdLinkToCB" />
            Auto-copy markdown link after fetch
        </label>
    </div>
</div>

@code {
    private string _url = "";
    private string _title = "";
    private string _mdLink = "";
    private bool _autoTitleToCB;
    private bool _autoMdLinkToCB;
    private bool _loading;

    protected override void OnInitialized()
    {
        var settings = AppSettings.Data;
        _autoTitleToCB = settings.FetchWebResource?.ResxTitleFetchToCB ?? false;
        _autoMdLinkToCB = settings.FetchWebResource?.ResxMdLinkFetchToCB ?? false;
    }

    private async Task FetchAsync()
    {
        if (string.IsNullOrWhiteSpace(_url)) return;
        _loading = true;
        Notify.Notify("Fetching resource title…");

        try
        {
            _title = await HtmlTitleRetriever.GetResouceTitleAsync(_url) ?? "";
            RefreshMdLink();
            await AutoCopyAfterFetch();
            Notify.NotifySuccess("Fetched successfully");
        }
        catch (Exception ex)
        {
            Notify.NotifyError($"Error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void RefreshMdLink()
    {
        var template = AppSettings.Data.FetchWebResource?.MdLinkTemplate ?? "[{0}]({1})";
        _mdLink = string.Format(template, _title, _url);
    }

    private async Task AutoCopyAfterFetch()
    {
        if (_autoTitleToCB) await Clipboard.CopyAsync(_title);
        else if (_autoMdLinkToCB) await Clipboard.CopyAsync(_mdLink);
    }

    private async Task CopyTitle() => await Clipboard.CopyAsync(_title);
    private async Task CopyMdLink() => await Clipboard.CopyAsync(_mdLink);

    // URL box:
    //   Enter             → fetch
    //   Shift+Enter       → refresh MD link only (no fetch)
    //   Ctrl+Enter        → enable MD-link auto-copy, then fetch
    //   Ctrl+Shift+Enter  → disable MD-link auto-copy, then fetch
    private async Task OnUrlKeyUp(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;

        if (e.CtrlKey)
        {
            _autoMdLinkToCB = !e.ShiftKey;
            _autoTitleToCB = false;
            await FetchAsync();
        }
        else if (e.ShiftKey)
        {
            RefreshMdLink();
        }
        else
        {
            await FetchAsync();
        }
    }

    // Title box:
    //   Enter             → refresh MD link + auto-copy (if enabled)
    //   Ctrl+Enter        → enable title auto-copy
    //   Ctrl+Shift+Enter  → disable title auto-copy
    private async Task OnTitleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;

        if (e.CtrlKey)
        {
            _autoTitleToCB = !e.ShiftKey;
            _autoMdLinkToCB = false;
        }
        else
        {
            RefreshMdLink();
            await AutoCopyAfterFetch();
        }
    }

    // Markdown-link box:
    //   Enter             → refresh MD link + auto-copy (if enabled)
    //   Ctrl+Enter        → enable MD-link auto-copy
    //   Ctrl+Shift+Enter  → disable MD-link auto-copy
    private async Task OnMdLinkKeyUp(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;

        if (e.CtrlKey)
        {
            _autoMdLinkToCB = !e.ShiftKey;
            _autoTitleToCB = false;
        }
        else
        {
            RefreshMdLink();
            await AutoCopyAfterFetch();
        }
    }
}
