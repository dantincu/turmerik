@inject IAppSettings AppSettings
@inject AppNotificationService Notify
@inject ClipboardService Clipboard

<div class="panel">
    <div class="panel-title">Path Converter</div>

    <div class="path-row">
        <span class="path-label">Windows Path</span>
        <input type="text" @bind="_winPath" @bind:event="oninput" @onkeyup="OnWinKeyUp"
               placeholder="C:\Users\…"
               title="Enter=convert | Ctrl+Enter=enable escaped-Win auto-copy | Ctrl+Shift+Enter=enable Unix auto-copy" />
        <button class="btn btn-primary" @onclick="ConvertFromWin">▶</button>
        <button class="btn btn-icon" @onclick="() => Clipboard.CopyAsync(_winPath)" title="Copy">⧉</button>
        <label class="checkbox-label"><input type="checkbox" @bind="_winToCB" /> Auto</label>
    </div>

    <div class="path-row">
        <span class="path-label">Escaped Win Path</span>
        <input type="text" @bind="_escWinPath" @bind:event="oninput" @onkeyup="OnEscWinKeyUp"
               placeholder="C:\\Users\\…"
               title="Enter=convert | Ctrl+Enter=enable Win auto-copy | Ctrl+Shift+Enter=enable Unix auto-copy" />
        <button class="btn btn-primary" @onclick="ConvertFromEscWin">▶</button>
        <button class="btn btn-icon" @onclick="() => Clipboard.CopyAsync(_escWinPath)" title="Copy">⧉</button>
        <label class="checkbox-label"><input type="checkbox" @bind="_escWinToCB" /> Auto</label>
    </div>

    <div class="path-row">
        <span class="path-label">Unix Path</span>
        <input type="text" @bind="_unixPath" @bind:event="oninput" @onkeyup="OnUnixKeyUp"
               placeholder="/home/user/…"
               title="Enter=convert | Ctrl+Enter=enable Win auto-copy | Ctrl+Shift+Enter=enable escaped-Win auto-copy" />
        <button class="btn btn-primary" @onclick="ConvertFromUnix">▶</button>
        <button class="btn btn-icon" @onclick="() => Clipboard.CopyAsync(_unixPath)" title="Copy">⧉</button>
        <label class="checkbox-label"><input type="checkbox" @bind="_unixToCB" /> Auto</label>
    </div>
</div>

@code {
    private string _winPath = "";
    private string _escWinPath = "";
    private string _unixPath = "";
    private bool _winToCB;
    private bool _escWinToCB;
    private bool _unixToCB;

    protected override void OnInitialized()
    {
        var s = AppSettings.Data.PathConverter;
        if (s == null) return;
        _winToCB    = s.WinPathToCB    ?? false;
        _escWinToCB = s.EscWinPathToCB ?? false;
        _unixToCB   = s.UnixPathToCB   ?? false;
    }

    private async Task ConvertFromWin()
    {
        _escWinPath = _winPath.Replace("\\", "\\\\");
        _unixPath   = NormPathH.NormPathUnixStyle(_winPath);
        if      (_escWinToCB) await Clipboard.CopyAsync(_escWinPath);
        else if (_unixToCB)   await Clipboard.CopyAsync(_unixPath);
        Notify.NotifySuccess("Converted from Windows path");
    }

    private async Task ConvertFromEscWin()
    {
        _winPath  = _escWinPath.Replace("\\\\", "\\");
        _unixPath = NormPathH.NormPathUnixStyle(_winPath);
        if      (_winToCB)  await Clipboard.CopyAsync(_winPath);
        else if (_unixToCB) await Clipboard.CopyAsync(_unixPath);
        Notify.NotifySuccess("Converted from escaped Windows path");
    }

    private async Task ConvertFromUnix()
    {
        _winPath = Path.IsPathRooted(_unixPath)
            ? NormPathH.NormRootedPathWinStyle(_unixPath)
            : _unixPath.Replace("/", "\\");
        _escWinPath = _winPath.Replace("\\", "\\\\");
        if      (_winToCB)    await Clipboard.CopyAsync(_winPath);
        else if (_escWinToCB) await Clipboard.CopyAsync(_escWinPath);
        Notify.NotifySuccess("Converted from Unix path");
    }

    // Win path box:
    //   Enter             → convert
    //   Ctrl+Enter        → enable esc-Win auto-copy (disable Unix), then convert
    //   Ctrl+Shift+Enter  → enable Unix auto-copy (disable esc-Win), then convert
    private async Task OnWinKeyUp(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (e.CtrlKey)
        {
            _escWinToCB = !e.ShiftKey;
            _unixToCB   = e.ShiftKey;
            _winToCB    = false;
        }
        await ConvertFromWin();
    }

    // Escaped Win path box:
    //   Enter             → convert
    //   Ctrl+Enter        → enable Win auto-copy (disable Unix), then convert
    //   Ctrl+Shift+Enter  → enable Unix auto-copy (disable Win), then convert
    private async Task OnEscWinKeyUp(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (e.CtrlKey)
        {
            _winToCB    = !e.ShiftKey;
            _unixToCB   = e.ShiftKey;
            _escWinToCB = false;
        }
        await ConvertFromEscWin();
    }

    // Unix path box:
    //   Enter             → convert
    //   Ctrl+Enter        → enable Win auto-copy (disable esc-Win), then convert
    //   Ctrl+Shift+Enter  → enable esc-Win auto-copy (disable Win), then convert
    private async Task OnUnixKeyUp(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (e.CtrlKey)
        {
            _winToCB    = !e.ShiftKey;
            _escWinToCB = e.ShiftKey;
            _unixToCB   = false;
        }
        await ConvertFromUnix();
    }
}
